<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ec.edu.espe.eurekadesktop.controllers.LoginController">
    <AnchorPane style="-fx-background-color: #0F172A;">
        <StackPane AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" 
                   AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0">
            <StackPane alignment="CENTER">
                <BorderPane maxWidth="500" maxHeight="600">
                    <top>
                        <VBox alignment="CENTER" BorderPane.alignment="CENTER">
                            <BorderPane.margin>
                                <Insets top="40"/>
                            </BorderPane.margin>
                            <Label text="EUREKA BANK" textFill="WHITE" style="-fx-font-size: 32px; -fx-font-weight: bold;">
                                <VBox.margin>
                                    <Insets top="20"/>
                                </VBox.margin>
                            </Label>
                            <Label text="Cliente Bancario Premium" textFill="#94A3B8" style="-fx-font-size: 14px;">
                                <VBox.margin>
                                    <Insets top="8"/>
                                </VBox.margin>
                            </Label>
                        </VBox>
                    </top>
                    <center>
                        <VBox spacing="20" BorderPane.alignment="CENTER">
                            <BorderPane.margin>
                                <Insets top="40" left="40" right="40"/>
                            </BorderPane.margin>
                            
                            <VBox spacing="8">
                                <Label text="Usuario" textFill="#94A3B8" style="-fx-font-size: 12px;"/>
                                <TextField fx:id="txtUsuario" promptText="Ingrese su usuario" 
                                           style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-prompt-text-fill: #64748B; -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;"/>
                            </VBox>
                            
                            <VBox spacing="8">
                                <Label text="Contraseña" textFill="#94A3B8" style="-fx-font-size: 12px;"/>
                                <PasswordField fx:id="txtPassword" promptText="Ingrese su contraseña"
                                              style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-prompt-text-fill: #64748B; -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;"/>
                            </VBox>
                            
                            <VBox spacing="8">
                                <Label text="Backend" textFill="#94A3B8" style="-fx-font-size: 12px;"/>
                                <ComboBox fx:id="cmbBackend" promptText="Seleccione el backend"
                                          style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-prompt-text-fill: #64748B; -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;"/>
                            </VBox>
                            
                            <Button fx:id="btnLogin" text="INICIAR SESIÓN" maxWidth="1.7976931348623157E308"
                                    style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"
                                    onAction="#handleLogin">
                                <padding>
                                    <Insets top="15" bottom="15" left="30" right="30"/>
                                </padding>
                            </Button>
                            
                            <Label fx:id="lblError" textFill="#EF4444" alignment="CENTER" 
                                   textAlignment="CENTER" wrapText="true" style="-fx-font-size: 12px;"/>
                        </VBox>
                    </center>
                    <bottom>
                        <Label text="© 2026 Eureka Bank - Sistema Financiero" textFill="#475569" 
                               BorderPane.alignment="CENTER">
                            <BorderPane.margin>
                                <Insets bottom="30"/>
                            </BorderPane.margin>
                        </Label>
                    </bottom>
                </BorderPane>
            </StackPane>
        </StackPane>
    </AnchorPane>
</StackPane>