<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ec.edu.espe.eurekadesktop.controllers.ConsultaController">
    <AnchorPane style="-fx-background-color: #0F172A;">
        <VBox spacing="20" AnchorPane.leftAnchor="40" AnchorPane.rightAnchor="40" 
              AnchorPane.topAnchor="40" AnchorPane.bottomAnchor="40">
            <HBox alignment="CENTER_LEFT">
                <Button fx:id="btnRegresar" text="Regresar" 
                        style="-fx-background-color: transparent; -fx-text-fill: #94A3B8; -fx-cursor: hand;"
                        onAction="#handleRegresar"/>
            </HBox>
            
            <Label text="CONSULTA DE MOVIMIENTOS" textFill="WHITE" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            
            <HBox spacing="15" alignment="CENTER_LEFT">
                <VBox spacing="5">
                    <Label text="Número de Cuenta" textFill="#94A3B8" style="-fx-font-size: 12px;"/>
                    <TextField fx:id="txtCuenta" promptText="Ej: 00100001" 
                               style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-prompt-text-fill: #64748B; -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
                </VBox>
                <Button fx:id="btnConsultar" text="CONSULTAR" 
                        style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"
                        onAction="#handleConsultar">
                    <padding>
                        <Insets top="10" bottom="10" left="20" right="20"/>
                    </padding>
                </Button>
            </HBox>
            
            <TableView fx:id="tablaMovimientos" style="-fx-background-color: #FFFFFF;" 
                       VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn text="Fecha" fx:id="colFecha" prefWidth="150"/>
                    <TableColumn text="Tipo" fx:id="colTipo" prefWidth="120"/>
                    <TableColumn text="Monto" fx:id="colMonto" prefWidth="120"/>
                    <TableColumn text="Descripción" fx:id="colDescripcion" prefWidth="200"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
            
            <Label fx:id="lblMensaje" textFill="#94A3B8" style="-fx-font-size: 12px;"/>
        </VBox>
    </AnchorPane>
</StackPane>