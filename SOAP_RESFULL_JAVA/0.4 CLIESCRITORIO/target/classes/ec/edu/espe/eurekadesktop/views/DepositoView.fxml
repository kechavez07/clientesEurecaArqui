<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ec.edu.espe.eurekadesktop.controllers.DepositoController">
    <AnchorPane style="-fx-background-color: #0F172A;">
        <VBox spacing="25" AnchorPane.leftAnchor="60" AnchorPane.rightAnchor="60" 
              AnchorPane.topAnchor="60" AnchorPane.bottomAnchor="60">
            <HBox alignment="CENTER_LEFT">
                <Button fx:id="btnRegresar" text="Regresar" 
                        style="-fx-background-color: transparent; -fx-text-fill: #94A3B8; -fx-cursor: hand;"
                        onAction="#handleRegresar"/>
            </HBox>
            
            <Label text="REGISTRAR DEPÓSITO" textFill="WHITE" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
            
            <VBox spacing="20" maxWidth="400" alignment="TOP_LEFT">
                <VBox spacing="8">
                    <Label text="Número de Cuenta" textFill="#94A3B8" style="-fx-font-size: 12px;"/>
                    <TextField fx:id="txtCuenta" promptText="Ej: 00100001" 
                               style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-prompt-text-fill: #64748B; -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 14;"/>
                </VBox>
                
                <VBox spacing="8">
                    <Label text="Importe ($)" textFill="#94A3B8" style="-fx-font-size: 12px;"/>
                    <TextField fx:id="txtImporte" promptText="Ej: 150.00" 
                               style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-prompt-text-fill: #64748B; -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 14;"/>
                </VBox>
                
                <Button fx:id="btnProcesar" text="PROCESAR DEPÓSITO" 
                        style="-fx-background-color: #22C55E; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"
                        onAction="#handleProcesar">
                    <padding>
                        <Insets top="15" bottom="15" left="30" right="30"/>
                    </padding>
                </Button>
            </VBox>
            
            <VBox fx:id="panelResultado" visible="false" spacing="15">
                <Label fx:id="lblResultado" textFill="#22C55E" style="-fx-font-size: 18px; -fx-font-weight: bold;" wrapText="true"/>
                <Label fx:id="lblDetalle" textFill="#94A3B8" style="-fx-font-size: 14px;" wrapText="true"/>
            </VBox>
            
            <Label fx:id="lblError" textFill="#EF4444" style="-fx-font-size: 12px;" wrapText="true"/>
        </VBox>
    </AnchorPane>
</StackPane>