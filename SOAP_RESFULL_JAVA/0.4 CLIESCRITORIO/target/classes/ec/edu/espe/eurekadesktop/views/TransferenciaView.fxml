<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ec.edu.espe.eurekadesktop.controllers.TransferenciaController">
    <AnchorPane style="-fx-background-color: #0F172A;">
        <StackPane AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" 
                   AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0">
            <StackPane alignment="CENTER">
                <BorderPane maxWidth="500" maxHeight="500">
                    <top>
                        <VBox alignment="CENTER" BorderPane.alignment="CENTER">
                            <BorderPane.margin>
                                <Insets top="40"/>
                            </BorderPane.margin>
                            <Label text="TRANSFERENCIA" textFill="WHITE" style="-fx-font-size: 28px; -fx-font-weight: bold;">
                                <VBox.margin>
                                    <Insets top="20"/>
                                </VBox.margin>
                            </Label>
                            <Label text="Envía dinero a otra cuenta" textFill="#94A3B8" style="-fx-font-size: 14px;">
                                <VBox.margin>
                                    <Insets top="8"/>
                                </VBox.margin>
                            </Label>
                        </VBox>
                    </top>
                    <center>
                        <VBox spacing="20" BorderPane.alignment="CENTER">
                            <BorderPane.margin>
                                <Insets top="40" left="40" right="40"/>
                            </BorderPane.margin>
                            
                            <VBox spacing="8">
                                <Label text="Cuenta Origen" textFill="#94A3B8" style="-fx-font-size: 12px;"/>
                                <TextField fx:id="txtCuentaOrigen" promptText="Número de cuenta origen" 
                                           style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-prompt-text-fill: #64748B; -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;"/>
                            </VBox>
                            
                            <VBox spacing="8">
                                <Label text="Cuenta Destino" textFill="#94A3B8" style="-fx-font-size: 12px;"/>
                                <TextField fx:id="txtCuentaDestino" promptText="Número de cuenta destino" 
                                           style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-prompt-text-fill: #64748B; -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;"/>
                            </VBox>
                            
                            <VBox spacing="8">
                                <Label text="Importe" textFill="#94A3B8" style="-fx-font-size: 12px;"/>
                                <TextField fx:id="txtImporte" promptText="Monto a transferir" 
                                           style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-prompt-text-fill: #64748B; -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;"/>
                            </VBox>
                            
                            <Button fx:id="btnTransferir" text="TRANSFERIR" maxWidth="1.7976931348623157E308"
                                    style="-fx-background-color: #8B5CF6; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"
                                    onAction="#handleTransferir">
                                <padding>
                                    <Insets top="15" bottom="15" left="30" right="30"/>
                                </padding>
                            </Button>
                            
                            <Button fx:id="btnRegresar" text="REGRESAR" maxWidth="1.7976931348623157E308"
                                    style="-fx-background-color: transparent; -fx-text-fill: #94A3B8; -fx-font-size: 14px; -fx-border-color: #64748B; -fx-border-radius: 8; -fx-cursor: hand;"
                                    onAction="#handleRegresar">
                                <padding>
                                    <Insets top="12" bottom="12" left="30" right="30"/>
                                </padding>
                            </Button>
                            
                            <Label fx:id="lblMensaje" textFill="#EF4444" alignment="CENTER" 
                                   textAlignment="CENTER" wrapText="true" style="-fx-font-size: 12px;"/>
                        </VBox>
                    </center>
                    <bottom>
                        <Label text="© 2026 Eureka Bank - Sistema Financiero" textFill="#475569" 
                               BorderPane.alignment="CENTER">
                            <BorderPane.margin>
                                <Insets bottom="30"/>
                            </BorderPane.margin>
                        </Label>
                    </bottom>
                </BorderPane>
            </StackPane>
        </StackPane>
    </AnchorPane>
</StackPane>